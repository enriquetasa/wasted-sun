#: wasted_sun/templates/day.html:24
#, python-format
msgid ""
"\n"
"    Spain’s peninsula wastes about %(eur_h)s per hour on average in "
"unused solar electricity\n"
"    (%(mwh_h)s), for this calendar day.\n"
"    "
msgstr ""
"\n"
"    La península española desperdicia unos %(eur_h)s por hora de media en"
" electricidad solar no utilizada\n"
"    (%(mwh_h)s), para este día natural.\n"
"    "

#: wasted_sun/templates/day.html:31
#, python-format
msgid ""
"\n"
"    Spain’s peninsula wastes about %(mwh_h)s per hour on average in "
"unused solar electricity (MWh), for this calendar day.\n"
"    "
msgstr ""
"\n"
"    La península española desperdicia unos %(mwh_h)s por hora de media en "
"electricidad solar no utilizada (MWh), para este día natural.\n"
"    "

#: wasted_sun/templates/day.html:37
