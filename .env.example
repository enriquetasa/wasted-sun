FLASK_ENV=development
SECRET_KEY=dev-change-me
BASE_URL=http://localhost:5000
APP_TIMEZONE=Europe/Madrid

# Production / Docker over HTTP only: set false so language cookie works without TLS
# SESSION_COOKIE_SECURE=false

# Mock mode is automatic when neither DATABASE_URL nor CUBE_API_URL is set.
# USE_MOCK_DATA=true forces mock even when a backend URL is configured.
# USE_MOCK_DATA=true

# Production web: Postgres only (fast reads, YTD enabled)
# WASTED_SUN_DATA_SOURCE=postgres
# DATABASE_URL=postgresql://reader:pass@host:5432/dbname

# Sync job only (writer DSN; falls back to DATABASE_URL)
# WASTED_SUN_SYNC_DATABASE_URL=postgresql://writer:pass@host:5432/dbname

# Cube.js — sync job + optional local live mode (not on production web)
# WASTED_SUN_DATA_SOURCE=cube
# CUBE_API_URL=https://your-cube-host
# CUBE_API_TOKEN=your-cube-api-secret
# Required: comma-separated codes that mean wasted sun (at least one variable; OR if both set)
# WASTED_SUN_CUBE_REDISPATCH_CODES=code1,code2
# WASTED_SUN_CUBE_RESTRICTION_TYPE_CODES=codeA,codeB
# WASTED_SUN_CUBE_HTTP_TIMEOUT_SEC=90
# Skip slow year-to-date Cube pulls (recommended until Cube has a sum measure)
# WASTED_SUN_CUBE_SKIP_YTD=true
# WASTED_SUN_CUBE_YTD_TIMEOUT_SEC=20

# Wide day table (i3dia-style qh_* columns)
# WASTED_SUN_PG_TABLE=your_table_or_view
# WASTED_SUN_PG_COL_DATE_DAY=date_day
# WASTED_SUN_PG_COL_TOTAL_MWH=total_mwh
# WASTED_SUN_PG_QH_SLOTS=100

# Illustrative EUR = MWh * rate (omit for MWh-only in production)
# WASTED_SUN_EUR_PER_MWH=65

# Optional: household analogy (kWh per home per day)
# HOUSEHOLD_DAY_KWH=12

# Pipeline freshness after Cube sync (preferred)
# WASTED_SUN_PG_AS_OF_META_TABLE=wasted_sun_sync_meta
# WASTED_SUN_PG_AS_OF_META_COLUMN=last_success_at
# Legacy single SELECT only (no semicolons/comments); do not combine with META_* above
# WASTED_SUN_PG_AS_OF_QUERY=SELECT max(updated_at) FROM your_meta

# Privacy-friendly analytics
# PLAUSIBLE_DOMAIN=your.domain
# PLAUSIBLE_SCRIPT_URL=https://plausible.io/js/script.js
