FLASK_ENV=development
SECRET_KEY=change-me
BASE_URL=http://localhost:5000
APP_TIMEZONE=Europe/Madrid

# Use mock data when unset or when explicitly enabled
# USE_MOCK_DATA=true
# DATABASE_URL=postgresql://reader:pass@host:5432/dbname

# Optional: household analogy (kWh per home per day, illustrative)
# HOUSEHOLD_DAY_KWH=12

# Postgres column mapping (defaults shown)
# WASTED_SUN_PG_TABLE=wasted_sun_hourly
# WASTED_SUN_PG_COL_TS=bucket_start
# WASTED_SUN_PG_COL_MWH=mwh_unused
# WASTED_SUN_PG_COL_EUR=eur_waste
# WASTED_SUN_PG_AS_OF_QUERY=SELECT max(updated_at) FROM wasted_sun_meta

# Privacy-friendly analytics (optional)
# PLAUSIBLE_DOMAIN=your.domain
# PLAUSIBLE_SCRIPT_URL=https://plausible.io/js/script.js
