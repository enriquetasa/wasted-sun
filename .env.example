FLASK_ENV=development
SECRET_KEY=dev-change-me
BASE_URL=http://localhost:5000
APP_TIMEZONE=Europe/Madrid

# Production / Docker over HTTP only: set false so language cookie works without TLS
# SESSION_COOKIE_SECURE=false

# Mock mode is automatic when DATABASE_URL is absent (regardless of USE_MOCK_DATA).
# Set DATABASE_URL to connect to Postgres; set USE_MOCK_DATA=true to force mock even with a DSN.
# DATABASE_URL=postgresql://reader:pass@host:5432/dbname
# USE_MOCK_DATA=true

# Wide day table (i3dia-style qh_* columns)
# WASTED_SUN_PG_TABLE=your_table_or_view
# WASTED_SUN_PG_COL_DATE_DAY=date_day
# WASTED_SUN_PG_COL_TOTAL_MWH=total_mwh
# WASTED_SUN_PG_QH_SLOTS=100

# Illustrative EUR = MWh * rate (omit for MWh-only in production)
# WASTED_SUN_EUR_PER_MWH=65

# Optional: household analogy (kWh per home per day)
# HOUSEHOLD_DAY_KWH=12

# Optional pipeline freshness (preferred: validated table + column → SELECT MAX(col) FROM table)
# WASTED_SUN_PG_AS_OF_META_TABLE=your_meta_table
# WASTED_SUN_PG_AS_OF_META_COLUMN=updated_at
# Legacy single SELECT only (no semicolons/comments); do not combine with META_* above
# WASTED_SUN_PG_AS_OF_QUERY=SELECT max(updated_at) FROM your_meta

# Privacy-friendly analytics
# PLAUSIBLE_DOMAIN=your.domain
# PLAUSIBLE_SCRIPT_URL=https://plausible.io/js/script.js
